# ==============================
# 🌍 Server Configuration
# ==============================
PORT=5000
NODE_ENV=development

# ==============================
# 🔑 JWT Configuration
# ==============================
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_ROTATION_THRESHOLD=7d

# ==============================
# 🗄️ Database Configuration
# ==============================
MONGO_URI=mongodb://127.0.0.1:27017/zenera

# ==============================
# 📦 Redis Configuration
# ==============================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ==============================
# 📧 Email Configuration
# ==============================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password

# ==============================
# 🛡️ Security
# ==============================
BCRYPT_SALT_ROUNDS=10

# ==============================
# 📁 Logging Configuration
# ==============================
LOG_LEVEL=info
LOG_FILE=/var/log/app.log
LOG_FORMAT=json
LOG_ROTATION=1day
LOG_MAX_FILES=10
LOG_MAX_SIZE=10MB

# ==============================
# 📊 Monitoring Configuration
# ==============================
MONITORING_URL=http://localhost:9200
MONITORING_INDEX=backend
MONITORING_INTERVAL=1h

# ==============================
# 🗂️ File Storage Configuration
# ==============================
FILE_STORAGE_URL=local
FILE_STORAGE_PATH=./public/uploads
FILE_STORAGE_MAX_SIZE=10MB
FILE_STORAGE_DEFAULT_FILENAME=example.jpg

# ==============================
# 🔒 CORS Configuration
# ==============================
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,Accept,Origin
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# ==============================
# 🗺️ API Configuration
# ==============================
API_URL=http://localhost:5000
API_VERSION=1.0.0
API_PREFIX=/api/v1
API_DEBUG=true
API_LOG_REQUESTS=true
API_RATE_LIMIT=1000
API_RATE_LIMIT_WINDOW=1h
API_ENABLE_CACHING=true
API_CACHE_TTL=3600
API_CACHE_MAX_SIZE=1000
REDIS_URL=redis://localhost:6379
